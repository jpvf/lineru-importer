# Aurora (read-only)
AURORA_HOST=your-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
AURORA_PORT=3306
AURORA_USER=readonly_user
AURORA_PASSWORD=
AURORA_SCHEMA=your_database

# Local MySQL container
MYSQL_ROOT_PASSWORD=changeme
MYSQL_USER=syncuser
MYSQL_PASSWORD=changeme
MYSQL_DATA_PATH=/Volumes/nvme/aurora-sync-mysql

# App
APP_PORT=8090
BATCH_SIZE=5000

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Twingate check interval (seconds, default 5 min)
TWINGATE_CHECK_INTERVAL=300
